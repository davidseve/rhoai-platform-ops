{
  "annotations": {
    "list": []
  },
  "description": "Search and browse individual traces by service, duration, and status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "",
                    "internal": {
                      "datasourceUid": "tempo",
                      "datasourceName": "Tempo",
                      "query": {
                        "queryType": "traceql",
                        "query": "${__data.fields[\"Trace ID\"]}"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ms" }
            ]
          }
        ]
      },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Start time", "desc": true }
        ],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "scope": "resource",
              "tag": "service.name",
              "operator": "=",
              "value": ["${service:raw}"],
              "valueType": "string"
            }
          ],
          "limit": 50,
          "refId": "A"
        }
      ],
      "title": "Traces",
      "type": "table"
    }
  ],
  "schemaVersion": 39,
  "tags": ["tracing", "tempo", "observability"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "tinyllama-test,tinyllama-fast",
        "current": { "text": "tinyllama-test", "value": "tinyllama-test" },
        "options": [
          { "text": "tinyllama-test", "value": "tinyllama-test", "selected": true },
          { "text": "tinyllama-fast", "value": "tinyllama-fast", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Trace Search",
  "uid": "maas-trace-search"
}
