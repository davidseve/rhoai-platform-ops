{
  "annotations": {
    "list": []
  },
  "description": "Trace exploration: service map, latency distribution, recent traces",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {},
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap",
          "refId": "A"
        }
      ],
      "title": "Service Map",
      "type": "nodeGraph"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "bucketSize": "auto",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "{{ service_name }} P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le, service_name))",
          "legendFormat": "{{ service_name }} P99",
          "refId": "B"
        }
      ],
      "title": "Latency Distribution (from spanmetrics)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": {
        "search": ""
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "scope": "resource",
              "tag": "service.name",
              "operator": "=",
              "value": ["tinyllama-test"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "refId": "A"
        }
      ],
      "title": "Recent Traces",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(traces_span_metrics_calls_total[5m])) by (service_name, span_kind)",
          "legendFormat": "{{ service_name }} ({{ span_kind }})",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Service (from spanmetrics)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["tracing", "tempo", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Trace Exploration",
  "uid": "maas-trace-exploration"
}
